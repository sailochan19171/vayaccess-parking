# Copy to `.env` and fill in real values.
# `.env` is gitignored — never commit credentials.

# Postgres connection string. Examples:
#   Neon:   postgresql+psycopg2://USER:PASS@HOST/DB?sslmode=require&channel_binding=require
#   Local:  postgresql+psycopg2://parkops_user:parkops_secret_2026@localhost:5432/parkops_db
#   SQLite: sqlite:///parking.db
DATABASE_URL=

# Set to 1 to run the admin/reports API only (no camera, no ML, no USB reader).
# Use this on Render/Fly/Koyeb free tiers and any host without local hardware.
CLOUD_MODE=0
